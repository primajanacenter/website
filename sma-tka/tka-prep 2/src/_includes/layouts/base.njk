<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or site.nama }} | {{ site.nama }}</title>
<meta name="description" content="{{ description or site.deskripsi }}">
<style>
{% inlineCSS "assets/css/main.css" %}
</style>
</head>
<body>
{% include "partials/header.njk" %}
<main>
<div class="container">
{{ content | safe }}
</div>
</main>
{% include "partials/footer.njk" %}
<script>
{% inlineJS "assets/js/storage.js" %}
</script>
{% if extraScripts %}
{% for js in extraScripts %}
<script>
{% inlineJS js %}
</script>
{% endfor %}
{% endif %}
</body>
</html>
