<h1>Pilih Mata Pelajaran Pilihan (Gratis)</h1>
<p>Isi tes minat singkat berikut untuk mendapat rekomendasi awal 2 mata uji pilihan sesuai rumpun ilmu & program studi tujuanmu. Untuk analisis yang lebih mendalam (gaya minat, prioritas karier, laporan lengkap), lihat versi PREMIUM di halaman <a href="/harga/">Harga</a>.</p>

<form class="assess" id="form-assessment">
  <label for="rumpun">Rumpun ilmu yang paling menarik minatmu</label>
  <select id="rumpun" name="rumpun" required>
    <option value="">-- Pilih --</option>
    {% for r in rumpunUnik %}
      <option value="{{ r }}">{{ r }}</option>
    {% endfor %}
  </select>

  <label for="minat">Ceritakan singkat minat/cita-cita kuliahmu (opsional)</label>
  <input type="text" id="minat" name="minat" placeholder="Contoh: ingin kuliah kedokteran">

  <div class="btn-row" style="justify-content:flex-start; margin-top:16px;">
    <button class="btn btn-primary" type="submit">Lihat Rekomendasi</button>
  </div>
</form>

<div id="hasil-assessment" class="section"></div>

<script>
var PENDUKUNG_DATA = {{ pendukungProdi | dump | safe }};
document.addEventListener("DOMContentLoaded", function () {
  TKASelfAssessment.init("form-assessment", "hasil-assessment", PENDUKUNG_DATA);
});
</script>
