---
pagination:
  data: mapel
  size: 1
  alias: item
permalink: "mata-pelajaran/{{ item.slug }}/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ item.nama }}"
  description: "{{ item.ringkasan }}"
---
<p><a href="/mata-pelajaran/">&larr; Semua Mata Pelajaran</a></p>
<span class="badge {{ 'badge-wajib' if item.kategori == 'wajib' else 'badge-pilihan' }}">{{ item.kategori | upper }}</span>
<h1>{{ item.nama }}</h1>

<section class="section">
  <h2>Definisi & Fokus</h2>
  <p>{{ item.definisi }}</p>
</section>

<section class="section">
  <h2>Muatan</h2>
  <ul>
  {% for m in item.muatan %}
    <li>{{ m }}</li>
  {% endfor %}
  </ul>
</section>

<section class="section">
  <h2>Kompetensi</h2>
  {% for k in item.kompetensi %}
    <h3>{{ k.nama }}</h3>
    <p>{{ k.deskripsi }}</p>
    <ul>
    {% for sub in k.subkompetensi %}
      <li>{{ sub }}</li>
    {% endfor %}
    </ul>
  {% endfor %}
</section>

<section class="section">
  <h2>Matriks Asesmen</h2>
  <table>
    <tr><th>Kompetensi</th><th>Bentuk Soal</th><th>Jenis Teks/Konteks</th></tr>
    {% for row in item.matriks %}
    <tr><td>{{ row.kompetensi }}</td><td>{{ row.bentukSoal }}</td><td>{{ row.jenisTeks }}</td></tr>
    {% endfor %}
  </table>
</section>

<section class="section">
  <h2>Contoh Soal</h2>
  {% for soal in item.contohSoal %}
    <div class="soal-box">
      {% if soal.stimulus %}<div class="stimulus">{{ soal.stimulus }}</div>{% endif %}
      <p><strong>{{ soal.pertanyaan }}</strong></p>
      <div class="pilihan-jawaban">
      {% for p in soal.pilihan %}
        <label>{{ ["A","B","C","D"][loop.index0] }}. {{ p }}</label>
      {% endfor %}
      </div>
      <p><em>Kunci: {{ soal.kunci }}</em></p>
      <p>{{ soal.pembahasan }}</p>
    </div>
  {% endfor %}
</section>

<section class="section">
  <a class="btn btn-primary" href="/tryout/{{ item.slug }}/">Coba Tryout {{ item.nama }} &rarr;</a>
</section>
