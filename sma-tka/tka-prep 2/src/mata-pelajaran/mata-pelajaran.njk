<h1>Mata Pelajaran TKA</h1>

<h2>Wajib</h2>
<div class="grid">
{% for item in mapel %}
  {% if item.kategori == "wajib" %}
  <div class="card">
    <span class="badge badge-wajib">WAJIB</span>
    <h3>{{ item.nama }}</h3>
    <p>{{ item.ringkasan }}</p>
    <a class="btn btn-outline" href="/mata-pelajaran/{{ item.slug }}/">Lihat Detail</a>
  </div>
  {% endif %}
{% endfor %}
</div>

<h2>Pilihan</h2>
<p class="disclaimer">Daftar ini akan terus dilengkapi. Lihat halaman <a href="/pilih-mapel/">Pilih Mapel</a> untuk rekomendasi 2 mapel pilihan sesuai program studi tujuanmu.</p>
<div class="grid">
{% for item in mapel %}
  {% if item.kategori == "pilihan" %}
  <div class="card">
    <span class="badge badge-pilihan">PILIHAN</span>
    <h3>{{ item.nama }}</h3>
    <p>{{ item.ringkasan }}</p>
    <a class="btn btn-outline" href="/mata-pelajaran/{{ item.slug }}/">Lihat Detail</a>
  </div>
  {% endif %}
{% endfor %}
</div>
