    <a class="btn btn-primary" href="/tryout/{{ item.slug }}/paket-1/">Mulai Tryout</a>
  </div>
  {% for nomor in [2,3,4,5,6] %}
  {% include "partials/premium-card.njk" %}
  {% endfor %}
</div>
